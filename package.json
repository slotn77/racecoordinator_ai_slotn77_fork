{
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint:client && npm run lint:server",
    "lint:client": "cd client && npx eslint --fix \"src/**/*.{ts,html}\"",
    "lint:server": "cd server && mvn spotless:check"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx,js,jsx,html}": [
      "eslint --fix --config client/.eslintrc.cjs --resolve-plugins-relative-to client",
      "prettier --write"
    ],
    "server/**/*.java": [
      "bash -c 'cd server && mvn spotless:apply'"
    ]
  }
}
